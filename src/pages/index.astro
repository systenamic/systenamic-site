---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Systenamic helps organisations move from planning to action on AI. Consulting, training, and hands-on project delivery." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Systenamic — Claude Cowork for SMEs</title>
  </head>
  <body>

    <!-- Nav -->
    <nav class="nav" id="nav">
      <a href="/" class="nav-wordmark">SYSTENAMIC</a>
      <ul class="nav-links">
        <li><a href="#what">[ WHAT WE DO ]</a></li>
        <li><a href="#services">[ SERVICES ]</a></li>
        <li><a href="#contact">[ GET IN TOUCH ]</a></li>
      </ul>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-glyph" aria-hidden="true">✻</div>
      <div>
        <p class="hero-eyebrow">AI CONSULTING · TRAINING · PROJECT DELIVERY</p>
        <h1 class="hero-headline">
          AI THAT <em>WORKS</em>
        </h1>
        <p class="hero-sub">
          There are more tools, more options, and more opinions than ever, and that makes it easy to feel stuck before you've begun. Systenamic helps organisations cut through the noise and actually get started.
        </p>
        <a href="#contact" class="hero-cta">[ GET IN TOUCH ]</a>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- What we do -->
    <section class="what" id="what">
      <div>
        <p class="what-label">[ 01 ] WHAT WE DO</p>
        <h2 class="what-headline">WHAT WE DO</h2>
      </div>
      <div class="what-body">
        <p>
          Most businesses have plans for AI. The harder part is deciding where to start and finding the resource to actually do it.
        </p>
        <p>
          Systenamic helps organisations move from planning to action. Whether that means working through the strategy, upskilling your team, or providing hands-on resource to get a project delivered, we work at whatever level is useful.
        </p>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Services -->
    <section class="services" id="services">
      <p class="services-label" style="color: var(--accent);">[ 02 ] SERVICES</p>
      <div class="services-grid">
        <div class="service-card">
          <p class="service-num">01</p>
          <h3 class="service-title">CONSULTING</h3>
          <p class="service-desc">
            We work with you to understand where AI can make a real difference, which problems are worth solving first, and what a practical plan looks like. The output is clarity: a grounded view of what to do, in what order, and why.
          </p>
        </div>
        <div class="service-card">
          <p class="service-num">02</p>
          <h3 class="service-title">TRAINING</h3>
          <p class="service-desc">
            Tailored training for teams who are starting to work with AI or want to use it more effectively. Built around your actual workflows and the tools you're already using, not generic principles.
          </p>
        </div>
        <div class="service-card">
          <p class="service-num">03</p>
          <h3 class="service-title">PROJECT DELIVERY</h3>
          <p class="service-desc">
            You have a clear goal but not the internal resource or expertise to get there. We work alongside your team to deliver the project, and leave your people better equipped to manage what comes next.
          </p>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Footer -->
    <footer class="footer" id="contact">
      <span class="footer-wordmark">SYSTENAMIC</span>
      <ul class="footer-links">
        <li><a href="mailto:hello@systenamic.com">[ HELLO@SYSTENAMIC.COM ]</a></li>
        <li><a href="https://substack.com/@systenamic" target="_blank" rel="noopener">[ SUBSTACK ]</a></li>
        <li><a href="https://linkedin.com/in/systenamic" target="_blank" rel="noopener">[ LINKEDIN ]</a></li>
      </ul>
      <p class="footer-meta">© 2026 SYSTENAMIC · BRISTOL, UK</p>
    </footer>

    <script>
      const nav = document.getElementById('nav');
      const onScroll = () => {
        nav?.classList.toggle('scrolled', window.scrollY > 10);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
    </script>

  </body>
</html>

---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Systenamic helps small businesses use AI for their marketing and content. We design workflows that fit how you work, install and personalise the right tools, and train your team." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Systenamic — Claude Cowork for SMEs</title>
  </head>
  <body>

    <!-- Nav -->
    <nav class="nav" id="nav">
      <a href="/" class="nav-wordmark">SYSTENAMIC</a>
      <ul class="nav-links">
        <li><a href="#what">[ WHAT WE DO ]</a></li>
        <li><a href="#services">[ SERVICES ]</a></li>
        <li><a href="#contact">[ GET IN TOUCH ]</a></li>
      </ul>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-glyph" aria-hidden="true">✻</div>
      <div>
        <p class="hero-eyebrow">AI FOR MARKETING & CONTENT · BRISTOL, UK</p>
        <h1 class="hero-headline">
          CONTENT THAT STILL SOUNDS LIKE <em>YOU</em>
        </h1>
        <p class="hero-sub">
          Content is one of the first things to slip when a small business gets busy. Systenamic helps you use AI for your marketing and content in a way that's faster, more consistent, and recognisably yours.
        </p>
        <a href="#contact" class="hero-cta">[ GET IN TOUCH ]</a>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- What we do -->
    <section class="what" id="what">
      <div>
        <p class="what-label">[ 01 ] WHAT WE DO</p>
        <h2 class="what-headline">COWORK, DONE PROPERLY</h2>
      </div>
      <div class="what-body">
        <p>
          There's never quite enough time for content. It's hard to stay consistent, and it's hard to sound like yourself when you're using AI tools out of the box.
        </p>
        <p>
          Systenamic helps small businesses use AI for their marketing and content. We design workflows that fit how you work, install and personalise the right tools, and train your team to use them.
        </p>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Services -->
    <section class="services" id="services">
      <p class="services-label">[ 02 ] SERVICES</p>
      <div class="services-grid">
        <div class="service-card">
          <p class="service-num">01</p>
          <h3 class="service-title">CONSULTING</h3>
          <p class="service-desc">
            We map out where AI can help your marketing and content: which workflows to build, how to set them up, and how to make sure what comes out still sounds like you. The goal is a content operation that's faster, more consistent, and recognisably yours.
          </p>
        </div>
        <div class="service-card">
          <p class="service-num">02</p>
          <h3 class="service-title">TRAINING</h3>
          <p class="service-desc">
            Focused, tailored training for your team on creating content and running marketing workflows with AI. Built around how your business works.
          </p>
        </div>
        <div class="service-card">
          <p class="service-num">03</p>
          <h3 class="service-title">PROJECT LEAD</h3>
          <p class="service-desc">
            You've identified the project but don't have the expertise or resource in-house to deliver it. We work together to get it done.
          </p>
        </div>
      </div>
    </section>

    <!-- Manifesto -->
    <section class="manifesto">
      <div class="manifesto-watermark" aria-hidden="true">SYSTENAMIC</div>
      <p class="manifesto-text">
        FASTER. MORE CONSISTENT. <em>RECOGNISABLY</em> YOURS.
      </p>
    </section>

    <hr class="section-divider" />

    <!-- Footer -->
    <footer class="footer" id="contact">
      <span class="footer-wordmark">SYSTENAMIC</span>
      <ul class="footer-links">
        <li><a href="mailto:hello@systenamic.com">[ HELLO@SYSTENAMIC.COM ]</a></li>
        <li><a href="https://substack.com/@systenamic" target="_blank" rel="noopener">[ SUBSTACK ]</a></li>
        <li><a href="https://linkedin.com/in/systenamic" target="_blank" rel="noopener">[ LINKEDIN ]</a></li>
      </ul>
      <p class="footer-meta">© 2026 SYSTENAMIC · BRISTOL, UK</p>
    </footer>

    <script>
      const nav = document.getElementById('nav');
      const onScroll = () => {
        nav?.classList.toggle('scrolled', window.scrollY > 10);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
    </script>

  </body>
</html>
